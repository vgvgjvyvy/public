{
    "schema":{
        "bsonType":"object",
        "description":"记录触发分享事件的日志",
        "required":[
        ],
        "permission":{
            "read":false,
            "create":false,
            "update":false,
            "delete":false
        },
        "properties":{
            "_id":{
                "description":"ID，系统自动生成"
            },
            "appid":{
                "bsonType":"string",
                "description":"客户端上报的应用ID"
            },
            "version":{
                "bsonType":"string",
                "description":"客户端上报的应用版本号"
            },
            "platform":{
                "bsonType":"string",
                "description":"客户端上报的平台code"
            },
            "channel":{
                "bsonType":"string",
                "description":"客户端上报的渠道code/场景值"
            },
            "device_id":{
                "bsonType":"string",
                "description":"客户端携带的设备标识"
            },
            "uid":{
                "bsonType":"string",
                "description":"用户编号, 对应uni-id-users._id"
            },
            "session_id":{
                "bsonType":"string",
                "description":"访问会话日志ID，对应uni-stat-session-logs._id",
