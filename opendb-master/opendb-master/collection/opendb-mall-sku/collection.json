{
  "schema": {
    "bsonType": "object",
    "required": ["goods_id", "sku_name", "price", "stock"],
    "properties": {
      "_id": {
        "description": "存储文档 ID（SKU ID），系统自动生成"
      },
      "goods_id": {
        "bsonType": "string",
        "description": "商品 id，参考 opendb-mall-goods 表",
        "foreignKey": "opendb-mall-goods._id"
      },
      "sku_name": {
        "bsonType": "string",
        "description": "SKU名称",
        "trim": "both"
      },
      "price": {
        "bsonType": "int",
        "description": "价格，以分为单位，避免浮点计算的精度问题"
      },
      "market_price": {
        "bsonType": "int",
        "description": "市场价，以分为单位，避免浮点计算的精度问题"
      },
      "stock": {
        "bsonType": "int",
        "description": "库存"
      },
      "weight": {
        "bsonType": "double",
        "title": "重量",
        "description": "重量，单位KG"
      },
      "create_date": {
        "bsonType": "timestamp",
        "description": "创建时间",
        "defaultValue": {
          "$env": "now"
        }
      },
      "update_date": {
        "bsonType": "timestamp",
        "description": "修改时间",
        "defaultValue": {
          "$env": "now"
        }
      }
    }
  },
  "index": [
    { "IndexName": "goods_id", "MgoKeySchema": { "MgoIndexKeys": [{ "Name": "goods_id", "Direction": "1" }], "MgoIsUnique": false } }
  ]
}
